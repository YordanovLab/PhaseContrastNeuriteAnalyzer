# Example shared pipeline settings for PhaseContrastNeuriteAnalyzer.
#
# Copy this file to config/pipeline_settings.env and edit the executable paths
# for your own machine. Keep PROJECT_ROOT as "." unless you intentionally moved
# the whole repository.

PROJECT_ROOT="."
OUTPUT_ROOT_DIR_NAME="pipeline_outputs"
INPUT_WORKSPACE_DIR_NAME="pipeline_inputs"
INPUT_MASTER_DIR="pipeline_inputs"
PRE_RENAMED_DIR_NAME="PRE_renamed"
IMAGE_INPUT_LIST_NAME="OUT_img_input1.txt"
OUT_CLEAR_BCGND_DIR_NAME="OUT_clear_bcgnd"
OUT_SEGMENTATION_DIR_NAME="OUT_segmentation"
OUT_OPTIMIZE_DIR_NAME="OUT_optimize"
OUT_ROI_DIR_NAME="ROIs"

# Linux/WSL examples. Edit these after installing Fiji and ilastik.
FIJI_BIN="/opt/imganalys/FIJI/Fiji.app/fiji-linux-x64"
ILASTIK_BIN="/opt/imganalys/ilastik-1.4.2rc1-gpu-Linux/run_ilastik.sh"

# Store trained ilastik .ilp files outside git or download them from the
# dataset/model release linked in README.md. If this path is missing, the app
# and shell launchers also look for a direct Zenodo-unzip fallback at:
# pipeline_inputs/ilastik/model/*.ilp
ILASTIK_PROJECT_FILE="models/Ilastik1_probably_working.ilp"
ILASTIK_MAX_PROCESSES="2"
APPLY_ILASTIK_RENORM="true"

# Default segmentation labels after mask remapping.
SEG_LABEL_NEURITES="3"
SEG_LABEL_CELL_BODIES="1"
SEG_LABEL_BACKGROUND="255"
SEG_LABEL_MAPPING_CONFIRMED="false"
SEG_LABEL_MAPPING_CONFIRMED_AT=""

# If this file is missing, the app and shell launchers also look for:
# pipeline_inputs/metadata/IN_sample_metadata_zenodo_paths.csv
SAMPLE_METADATA_FILE="pipeline_inputs/IN_sample_metadata.csv"
MASK_PERCENTAGES_FILE="mask_area_percentages.csv"
OPTIM_GROUPS_FILE="mask_area_percentages+optim_groups.csv"
OPTIM_GROUPS_INSPECTED_FILE="mask_area_percentages+optim_groups+inspected.csv"
OPT_RDS_FILE="optROIs_data.rds"

PIPELINE_OPERATION_MODE="optimization"
OPTIMIZATION_SCORING_MODE="ensemble_union_continuity_topology"
ACTIVE_OPTIMIZATION_PROFILE=""
ACTIVE_VALIDATION_PROFILE=""
VALIDATION_PROFILE_DIR_NAME="cache/validation_profiles"
