# PhaseContrastNeuriteAnalyzer repository hygiene
#
# Keep the GitHub repository lightweight and reproducible. Raw microscopy data,
# ilastik training data, generated masks, ROIs, logs, reports, and local machine
# settings should live outside git or in an external data repository.

# Local/generated pipeline state
cache/
zenodo_upload/
pipeline_inputs/*
pipeline_outputs/*
!pipeline_inputs/
!pipeline_inputs/README.md
!pipeline_outputs/
!pipeline_outputs/README.md
OUT_*/
PRE_renamed/
OUT_img_input1.txt

# Local settings; commit the example template instead.
config/pipeline_settings.env
!config/pipeline_settings.example.env

# Large microscopy/model artifacts
Ilastik_model_neurites_sh-sy5y/
*.ilp
*.h5
*.hdf5
*.n5
*.zarr/
*.tif
*.tiff
*.czi
*.lif
*.nd2
*.oib
*.oif
*.roi
*.zip
*.tar
*.tar.gz
*.tgz
*.7z
*.rar

# Generated analysis tables/objects that may become large
*.rds
*.RData
*.rda
*_analysis_raw.csv
*_filtered_rois.csv
generalized_model_feature_table.csv
generalized_model_feature_table.rds

# Logs and diagnostics generated by runs
*.log
*_detailed_log.txt
*_diagnostics.csv
command_history.csv
PROJECT_FILE_STATUS.txt

# Temporary helper scripts/manifests created while staging external uploads
cache/zenodo_staging/

# OS/editor noise
.DS_Store
Thumbs.db
desktop.ini
.Rhistory
.RDataTmp
.Rproj.user/
.vscode/
.idea/

# Python/Node cache if helper tooling is added later
__pycache__/
*.pyc
node_modules/
